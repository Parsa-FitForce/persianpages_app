# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/persianpages

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Google OAuth (optional - get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps / Places API (for address autocomplete + map display)
GOOGLE_PLACES_API_KEY=your-google-places-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# LLM Configuration (OpenAI primary, Anthropic fallback)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Admin API key for scrape/enrich endpoints
ADMIN_API_KEY=your-admin-api-key

# Yelp Fusion API (free alternative to Google Places for scraping)
YELP_API_KEY=your-yelp-api-key

# Twilio (for phone verification)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=your-twilio-phone-number
# TWILIO_MESSAGING_SID=your-twilio-messaging-service-sid  # alternative to FROM_NUMBER
TWILIO_VERIFY_SID=your-twilio-verify-service-sid  # preferred: uses Twilio Verify API

# AWS SES (for email verification & password reset)
SES_FROM_EMAIL=noreply@persianpages.com
SES_REGION=us-east-1

# Server
PORT=5000
CLIENT_URL=http://localhost:3000
